# ============================================
# SalesAI Configuration
# ============================================

# --------------------------------------------
# AI/LLM Configuration (REQUIRED)
# --------------------------------------------
# Get your Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model selection
# GEMINI_MODEL=gemini-2.0-flash-exp

# --------------------------------------------
# SMTP Email Configuration
# --------------------------------------------
# Gmail settings (recommended for production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_STARTTLS=true
SMTP_USE_AUTH=true
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_NAME=Sales AI
SMTP_FROM_EMAIL=your_email@gmail.com

# Test email recipient
TEST_EMAIL_TO=test@example.com

# --------------------------------------------
# Dry Run Mode (IMPORTANT)
# --------------------------------------------
# Set to 'true' to prevent actual email sending (prints to console only)
# Set to 'false' to send real emails
DRY_RUN=true

# --------------------------------------------
# Product Configuration (Optional)
# --------------------------------------------
# PRODUCT_NAME=SalesAI Copilot
# PRODUCT_VALUE_PROP=helps sales teams automatically prioritize leads and draft highly personalized outreach, saving hours per week.

# --------------------------------------------
# Legacy Ollama Settings (NOT USED)
# --------------------------------------------
# These are kept for reference but not used
# The app now uses Gemini instead of Ollama
OLLAMA_MODEL=llama3.1
OLLAMA_URL=http://localhost:11434
